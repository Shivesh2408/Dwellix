# Dwellix - AI-Powered Home Management Platform Configuration Templates

###############################################################################
# BACKEND SERVER CONFIGURATION (Default directory: /backend)
###############################################################################
SERVER_PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/dwellix
DATABASE_USERNAME=dwellix
DATABASE_PASSWORD=dwellix

# JWT Secrets & Configuration
# Generate a 256-bit or 512-bit key encoded in Base64
JWT_SECRET=ZGV2ZWxvcG1lbnQtZGV2ZWxvcG1lbnQtZGV2ZWxvcG1lbnQtZGV2ZWxvcG1lbnQtMTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NQ==
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Auth Cookie Settings
AUTH_REFRESH_COOKIE_NAME=dwellix_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

# Google OAuth Integrations (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenRouter & Cloudinary API Keys (Required for AI Copilot / Image Uploads)
OPENROUTER_API_KEY=your-openrouter-api-key
CLOUDINARY_URL=cloudinary://your-cloudinary-api-key-and-secret

# Rate Limiting Parameters
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60


###############################################################################
# FRONTEND CONFIGURATION (Default directory: /frontend)
###############################################################################
# The local development or production URL of the API gateway (backend)
NEXT_PUBLIC_API_URL=http://localhost:8080